  logTestCase("TC-AC-002", "交流放电全流程测试");
  write("  Category: 交流放电模式");
  write("  Description: 验证交流放电模式启动、运行、停止全流程");
  write("  Precondition: 1. 设备上电待机2. 无故障告警3. 交流负载可接入");
  write("  Steps:");
  executeStep("1. 首页点击【交流放电】");
  executeStep("2. 弹窗点击 YES 确认");
  executeStep("3. 查看放电运行界面");
  executeStep("4. 点击停止按钮退出");
  verifyExpectation("1. 屏幕弹窗：是否启动交流放电模式？→ 点 YES");
  verifyExpectation("2. 进入交流放电页面，显示：放电模式、放电中、三相电压、放电电流、放电功率");
  verifyExpectation("3. 报文：715xh (TCU_ModeCtrl=3)、18F0310Axh (TCU_ModeSts=3)");
  verifyExpectation("4. 停止后首页显示：交流放电关");
  write(" ");
}

