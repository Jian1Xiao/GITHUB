  verifyExpectation("2. 二级（欠压）：屏显 "直流欠压"，报文 Fault_Level=2，功率 25kW");
  verifyExpectation("3. 三级（通信）：屏显 "通信故障"，报文 Fault_Level=3，功率 0kW");
  write(" ");
}

