void runCase_SOP_005()
{
  logTestCase("SOP-005", "临工新能源电池(71kwh) 
 20℃~45℃、SOC0%~60% 1C 倍率充电验证");
  write("  Priority: 1-High");
  write("  Description: 验证临工新能源电池在适宜充电温度区间、低中 SOC 段，充电 SOP 可支持 1C 倍率正常充电，无降额限流");
  write("  Precondition: 1. 整机高压上电完成，无故障、无告警；2. 搭载临工新能源配套电池；3. 充电回路正常，无保护限制触发");
  write("  Steps:");
  executeStep("1. 电池温度 20℃~45℃；");
  executeStep("2.SOC 区间 0%~60%；");
  executeStep("3. 下发充电指令，开启 1C 倍率充电；");
  executeStep("4. 监控充电 SOP 报文、实际充电电流、整机屏显及后台平台");
  verifyExpectation("电池理论 1C 充电功率为 71kW，BMS 充电 SOP 开放 1C 倍率权限；受整机硬件限制，实际以 30kW 满功率稳定充电；系统无降功率、无告警");
  write(" ");
}

void runCase_SOP_006()
{
  logTestCase("SOP-006", "临工新能源电池(107kwh) 
 20℃~45℃、SOC0%~60% 1C 倍率充电验证");
  write("  Priority: 1-High");
  write("  Description: 验证临工新能源电池在适宜充电温度区间、低中 SOC 段，充电 SOP 可支持 1C 倍率正常充电，无降额限流");
  write("  Precondition: 1. 整机高压上电完成，无故障、无告警；2. 搭载临工新能源配套电池；3. 充电回路正常，无保护限制触发");
  write("  Steps:");
  executeStep("1. 电池温度 20℃~45℃；");
  executeStep("2.SOC 区间 0%~60%；");
  executeStep("3. 下发充电指令，开启 1C 倍率充电；");
  executeStep("4. 监控充电 SOP 报文、实际充电电流、整机屏显及后台平台");
  executeStep("1、整机高压上电完成");
  executeStep("2、查看报文");
  executeStep("1、整机高压上电完成");
  executeStep("2、查看报文");
  executeStep("1、整机高压上电完成");
  executeStep("2、查看报文");
  executeStep("1、整机高压上电完成");
  executeStep("2、查看报文");
  executeStep("1、整机高压上电完成");
  executeStep("2、查看报文");
  executeStep("1. BMS接通，上位机与其连接正常；2. 上位机选择本地匹配升级文件，点击开始升级；3. 升级完成后重启BMS，验证版本及功能。");
  verifyExpectation("电池理论 1C 充电功率为 107kw，BMS 充电 SOP 开放 1C 倍率权限；受整机硬件限制，实际以 60kw 满功率稳定充电；系统无降功率、无告警");
  verifyExpectation("18FF01F3xh soc=");
  verifyExpectation("18FF01F3xh Vol_Bat=");
  verifyExpectation("18FF01F3xh cur_Bat=");
  verifyExpectation("18FF02F3xh BMS_BatStatus=2");
  verifyExpectation("18FF05F3xh InsulationValue=");
  verifyExpectation("1. 连接稳定，文件识别正常；2. 升级无卡顿，完成后自动重启；3. 版本匹配，BMS功能正常。");
  write(" ");
}

void runCase_Display_001()
{
  logTestCase("Display-001", "待机信息显示");
  write("  Category: 显示屏功能测试");
  write("  Priority: 1-High");
  write("  Description: 桩上电后观察显示屏界面的显示信息，显示正常");
  write("  Precondition: 桩 ON 挡电");
  write("  Steps:");
  executeStep("1. 桩处于上电状态");
  verifyExpectation("1. 显示储能桩的 VCU 发出的 VIN、BMS 发出的充电车 SOC；显示屏显示充电二维码；显示屏显示年月日和星期2. 显示交流放电和补电开关");
  write(" ");
}

void runCase_Display_002()
{
  logTestCase("Display-002", "界面跳转");
  write("  Priority: 1-High");
  write("  Description: 界面跳转逻辑");
  write("  Precondition: 桩处于 ON 挡");
  write("  Steps:");
  executeStep("1. 将充电枪插入目标��辆");
  executeStep("2. 桩开始放电");
  executeStep("3. 结束放电，未拔枪");
  executeStep("4. 充电枪即不再挂枪位也不在充电位");
  executeStep("5. 充电枪归位");
  verifyExpectation("1. 充电枪连接成功，显示屏显示充电二维码，并提示用户扫码启动充电");
  verifyExpectation("2. 开始放电，显示屏页面跳转至充电中界面，显示充电电量，SOC，充电功率，电流，电压信息");
  verifyExpectation("3. 显示 TCU 发出的充电功率、充电电压、充电电流、被充车辆 SOC、剩余充电时间、已充时间");
  verifyExpectation("4. 显示屏提示用户充电结束，将充电枪插回挂枪插座");
  verifyExpectation("5. 显示充电时长、电量、结束 SOC，10s 后回到待机界面");
  write(" ");
}

