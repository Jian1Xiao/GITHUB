  write(" ");
}

void runCase_VCU_007()
{
  logTestCase("VCU_007", "充电停止 SOC 确认");
  write("  Priority: 1-High");
  write("  Description: 充电至 SOC=100% 或设定值后自动停止");
  write("  Precondition: 电池 SOC < 90%，充电功能正常");
  write("  Steps:");
  executeStep("1. 启动充电");
  executeStep("2. 监控 SOC 变化");
  executeStep("3. 观察在 SOC=100% 时的停止行为");
  verifyExpectation("1. SOC 逐步增加");
  verifyExpectation("2. SOC 到达 100% 后 5s 内停止充电");
  verifyExpectation("3. 屏显 "充电完成"，继电器断开");
  write(" ");
}

void runCase_VCU_008()
