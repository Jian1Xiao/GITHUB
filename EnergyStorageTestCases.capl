void runCase_BMS_001()
{
  logTestCase("BMS_001", "直流放电（即插即用）");
  write("  Category: 直流放电");
  write("  Priority: 1-High");
  write("  Description: 将枪插入目标车辆/充电测试箱，tcu检测到充电枪连接到被充车辆时即进行放电");
  write("  Precondition: 整车处于上电状态，BMS,CCU自检通过");
  write("  Steps:");
  executeStep("1.车辆上ON档电");
  executeStep("通过屏幕设置放电模式为直流放电");
  executeStep("2.插入充电枪");
  executeStep("3.TCU检测到充电枪连接成功");
  executeStep("4.Tcu闭合K10和K20继电器");
  executeStep("5.60kw DCDC开始工作");
  executeStep("6.BMS开始放电");
  executeStep("8.按下显示屏停止放电按钮");
  executeStep("9.断开K1、K2继电器");
  executeStep("10.断开放负放正继电器");
  verifyExpectation("715xh TCU_ModeCtrl=0");
  verifyExpectation("充电枪连接正常");
  verifyExpectation("10228AF6xh CC_ConnectCarStatus=0");
  verifyExpectation("报文ID:18F102F6xh信号ChargeModeRseponse=5（1：遥控方式；2");
  verifyExpectation("扫码方式；5：即插即充），开始自动放电");
  verifyExpectation("10228AF6 CC_K10=1");
  verifyExpectation("CC_K20=1");
  verifyExpectation("DCDC灯闪烁和风扇转动");
  verifyExpectation("18FF02F3 BMS_BatStatus=12（增加实际功能表现放电电流电压）");
  verifyExpectation("8.显示屏下发 1003F68A VCU_ChargePortID=01/02");
  verifyExpectation("VCU_ChargeStopReason = 1，风扇停止运行");
  verifyExpectation("9.10228AF6");
  verifyExpectation("CC_K10=0，CC_K20=0");
  verifyExpectation("10.18FF06F3  DisChargNegativeRelay=2");
  verifyExpectation("DisChargPositiveRelay=2");
  write(" ");
}

