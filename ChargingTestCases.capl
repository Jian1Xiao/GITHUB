/*
  Auto-generated CAPL test suite from 充电.xlsx
  Contains generated test case routines for charging scenarios
*/

variables
{
  msTimer testTimer;
}

void logTestCase(char id[], char title[])
{
  write("=== Charging Test Case %s: %s ===", id, title);
}

void executeStep(char step[])
{
  write("  STEP: %s", step);
}

void verifyExpectation(char expected[])
{
  write("  EXPECT: %s", expected);
}

void runAllChargingTestCases()
{
  write("Starting generated charging test suite...");
  runCase_BMS_001();
  runCase_BMS_002();
  runCase_BMS_007();
  runCase_BMS_008();
  runCase_BMS_009();
  runCase_BMS_009();
  runCase_BMS_010();
  runCase_BMS_011();
  runCase_BMS_011();
  runCase_BMS_012();
  runCase_BMS_013();
  runCase_SOP_001();
  runCase_SOP_002();
  runCase_SOP_003();
  runCase_SOP_004();
  runCase_SOP_005();
  runCase_SOP_006();
  write("Generated charging test suite complete.");
}

on start
{
  runAllChargingTestCases();
}

void runCase_BMS_001()
{
  logTestCase("BMS_001", "直流放电（即插即用） ");
  write("  Category: 直流放电");
  write("  Priority: 1-High");
  write("  Description: 将枪插入目标车辆/充电测试箱，tcu检测到充电枪连接到被充车辆时即进行放电");
  write("  Precondition: 整车处于上电状态，BMS,CCU自检通过");
  write("  Steps:");
  executeStep("1.车辆上ON档电");
  executeStep("通过屏幕设置放电模式为直流放电");
  executeStep("2.插入充电枪");
  executeStep("3.TCU检测到充电枪连接成功");
  executeStep("4.Tcu闭合K10和K20继电器");
  executeStep("5.60kw DCDC开始工作");
  executeStep("6.BMS开始放电");
  executeStep("8.按下显示屏停止放电按钮");
  executeStep("9.断开K1、K2继电器");
  executeStep("10.断开放负放正继电器");
  write("  Expected:");
  verifyExpectation("715xh TCU_ModeCtrl=0");
  verifyExpectation("充电枪连接正常");
  verifyExpectation("10228AF6xh CC_ConnectCarStatus=0");
  verifyExpectation("报文ID:18F102F6xh信号ChargeModeRseponse=5（1：遥控方式；2");
  verifyExpectation("扫码方式；5：即插即充），开始自动放电");
  verifyExpectation("10228AF6 CC_K10=1");
  verifyExpectation("CC_K20=1");
  verifyExpectation("DCDC灯闪烁和风扇转动");
  verifyExpectation("18FF02F3 BMS_BatStatus=12（增加实际功能表现放电电流电压）");
  verifyExpectation("8.显示屏下发 1003F68A VCU_ChargePortID=01/02");
  verifyExpectation("VCU_ChargeStopReason = 1，风扇停止运行");
  verifyExpectation("9.10228AF6");
  verifyExpectation("CC_K10=0，CC_K20=0");
  verifyExpectation("10.18FF06F3  DisChargNegativeRelay=2");
  verifyExpectation("DisChargPositiveRelay=2");
  write(" ");
}

void runCase_BMS_002()
{
  logTestCase("BMS_002", "直流放电（扫码放电） ");
  write("  Priority: 1-High");
  write("  Description: 将枪插入目标车辆/充电测试箱，扫描二维码对tcu发送启停充电指令");
  write("  Precondition: 整车处于上电状态，BMS,CCU自检通过");
  write("  Steps:");
  executeStep("1.车辆上ON档电");
  executeStep("通过屏幕设置放电模式为直流放电");
  executeStep("2.插入充电枪");
  executeStep("3用户通过云平台对tcu发送启停充电指令（扫码）");
  executeStep("5.Tcu闭合K10和K20继电器");
  executeStep("6.60kw DCDC开始工作");
  executeStep("7.BMS开始放电");
  executeStep("8.按下显示屏停止放电按钮/点击小程序结束冲电");
  executeStep("9.断开K1、K2继电器");
  executeStep("10.断开放负放正继电器");
  executeStep("1.车辆上ON档电");
  executeStep("通过屏幕设置放电模式为交流放电");
  executeStep("TCU控制ACDC进行逆变，为380V插座供电");
  executeStep("1.车辆上ON档电");
  executeStep("通过屏幕设置放电模式为交流放电");
  executeStep("TCU控制ACDC进行逆变，为三个220V插座供电");
  executeStep("1.插入充电枪");
  executeStep("2.BMS控制充负1和充负2继电器闭合");
  executeStep("3.等待3min");
  executeStep("4.结束放电");
  executeStep("1、通过显示屏将整机模式切换为交流补电模式；");
  executeStep("2、TCU接收到交流补电指令后，控制ACDC进入到整流模式；");
  executeStep("3、将工业电接入到整机，系统进行交流补电。");
  executeStep("TCU根据BMS的状态请求，控制ACDC进入到恒流/恒压充电模式");
  executeStep("2.BMS控制充负1和充负2继电器闭合");
  executeStep("3.等待3min");
  executeStep("4.结束放电");
  write("  Expected:");
  verifyExpectation("715xh TCU_ModeCtrl=0");
  verifyExpectation("充电枪连接正常");
  verifyExpectation("10228AF6xh CC_ConnectCarStatus=0");
  verifyExpectation("报文ID:18F102F6xh信号ChargeModeRseponse=2（1：遥控方式；2");
  verifyExpectation("扫码方式；5：即插即充），开始自动放电");
  verifyExpectation("TCU照GB/T 27930进行充电，并实时上传电量、功率、电压、电流等信息给平台");
  verifyExpectation("10228AF6 CC_K10=1");
  verifyExpectation("CC_K20=1");
  verifyExpectation("DCDC灯闪烁和风扇转动");
  verifyExpectation("18FF02F3 BMS_BatStatus=12（增加实际功能表现放电电流电压）");
  verifyExpectation("8.显示屏下发 1003F68A VCU_ChargePortID=01/02");
  verifyExpectation("VCU_ChargeStopReason = 1，风扇停止运行");
  verifyExpectation("平台下发停止放电VCU_ChargeStopReason = 1，风扇停止运行");
  verifyExpectation("9.10228AF6");
  verifyExpectation("CC_K10=0，CC_K20=0");
  verifyExpectation("10.18FF06F3  DisChargNegativeRelay=2");
  verifyExpectation("DisChargPositiveRelay=2");
  verifyExpectation("715xh TCU_ModeCtrl=3");
  verifyExpectation("插座有电，用电器可正常工作");
  verifyExpectation("715xh TCU_ModeCtrl=3");
  verifyExpectation("插座有电，用电器可正常工作");
  verifyExpectation("1.充电桩与充电柜连接成功");
  verifyExpectation("2.18FF06F3 ChargPositiveRelay1 = 1");
  verifyExpectation("ChargNegativeRelay1=1");
  verifyExpectation("3.补能功率按照MAP图输出，12V蓄电池开始充电");
  verifyExpectation("4.断开充正充负继电器");
  verifyExpectation("715xh TCU_ModeCtrl=2");
  verifyExpectation("18F0305Axh Mod_Char=0");
  verifyExpectation("2.18FF06F3 ChargPositiveRelay1 = 1");
  verifyExpectation("ChargNegativeRelay1=1");
  verifyExpectation("3.补能功率按照MAP图输出，12V蓄电池开始充电");
  verifyExpectation("4.断开充正充负继电器");
  write(" ");
}

