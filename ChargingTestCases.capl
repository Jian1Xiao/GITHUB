  executeStep("4. 监控充电 SOP 报文、实际充电电流、整机屏显及后台平台");
  write("  Expected:");
  verifyExpectation("电池理论 1C 充电功率为 71kW，BMS 充电 SOP 开放 1C 倍率权限；受整机硬件限制，实际以 30kW 满功率稳定充电；系统无降功率、无告警，充电运行正常");
  write(" ");
}

