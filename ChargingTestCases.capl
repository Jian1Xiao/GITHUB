void runCase_BMS_008()
{
  logTestCase("BMS_008", "故障等级处理 ");
  write("  Priority: 1-High");
  write("  Description: 一 / 二 / 三级故障响应");
  write("  Precondition: 交流放电（50kW）");
  write("  Steps:");
  executeStep("1.CANoe 依次强制一 / 二 / 三级故障");
  write("  Expected:");
  verifyExpectation("1. 一级（过温）：屏显 “环境过温”，报文 Fault_Level=1，功率 50kW 不变");
  verifyExpectation("2. 二级（欠压）：屏显 “直流欠压”，报文 Fault_Level=2，功率 25kW");
  verifyExpectation("3. 三级（通信）：屏显 “通信故障”，报文 Fault_Level=3，功率 0kW");
  write(" ");
}

