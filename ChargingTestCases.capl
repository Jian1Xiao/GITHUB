void runCase_SOP_001()
{
  logTestCase("SOP-001", "兰钧电池 25℃~40℃、SOC85%~100% 满功率放电验证 ");
  write("  Category: sop表发送-放电 SOP 测试");
  write("  Priority: 1-High");
  write("  Description: 验证兰钧电池在标准常温区间、高 SOC 区间下，BMS 放电 SOP 输出额定满功率，整车 / 整机无降功率限制");
  write("  Precondition: 1、设备高压上电完成，系统无故障；2、电池为兰钧磷酸铁锂电池；3、无告警、无保护限制");
  write("  Steps:");
  executeStep("1、电池温度 25℃~40℃；");
  executeStep("2、 SOC 区间为 85%~100%；");
  executeStep("3、下发放电指令，开启满功率放电；");
  executeStep("4、监控 BMS 放电 SOP 报文、实际放电功率、上位机与屏显状态");
  write("  Expected:");
  verifyExpectation("1、BMS 上报最大放电 SOP 为额定满功率60kw；");
  verifyExpectation("2、系统无降功率限流逻辑；");
  verifyExpectation("3、实际放电功率正常拉满，运行稳定4、屏显、后台平台无功率受限告警");
  write(" ");
}

void runCase_SOP_002()
{
  logTestCase("SOP-002", "临工新能源电池(107kwh) 15℃~45℃、SOC20%~100% 满功率放电验证 ");
  write("  Priority: 1-High");
  write("  Description: 验证临工新能源电池常规工作温区、全段可用 SOC 范围内，放电 SOP 允许满功率输出，无主动降功率限制");
  write("  Precondition: 1. 设备高压上电正常，整机无故障、无告警；2. 电池为临工新能源配套电池；3. 系统无保护限流触发");
  write("  Steps:");
  executeStep("1. 电池温度 15℃~45℃；");
  executeStep("2.SOC 区间 20%~100%；");
  executeStep("3. 下发放电指令，执行满功率放电；");
  executeStep("4. 持续监控 BMS 放电 SOP 报文、实际放电功率及屏显、平台状态");
  write("  Expected:");
  verifyExpectation("1、BMS 上报最大放电 SOP 为额定满功率60kw；");
  verifyExpectation("2、系统无降功率、限流限制；");
  verifyExpectation("3、实际放电可稳定满功率运行；");
  verifyExpectation("4、显示屏及平台无功率受限类告警");
  write(" ");
}

